# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/kaigo_development

# Admin Panel Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Admin notification email
ADMIN_EMAIL=info@kaigo-society.org

# Brevo SMTP (https://app.brevo.com > Settings > SMTP & API)
BREVO_SMTP_LOGIN=your-brevo-login@example.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-key

# Application Host (for email links)
APP_HOST=localhost:3000
