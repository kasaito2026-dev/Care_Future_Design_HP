<div class="page-header">
    <div class="container">
        <span class="page-label">Contact</span>
        <h1 class="page-title">お問い合わせ</h1>
    </div>
</div>

<div class="content-area py-section">
    <div class="container">
        <div class="contact-form-area fade-in" style="max-width: 700px; margin: 0 auto;">
            <p style="margin-bottom: 2rem; color: var(--color-gray-600);">
                以下のフォームに必要事項をご入力の上、送信してください。<br>
                3営業日以内にご連絡させていただきます。
            </p>

            <% if flash[:notice] %>
                <div style="background: #d4edda; color: #155724; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
                    <%= flash[:notice] %>
                </div>
            <% end %>

            <div style="text-align: center; padding: 40px; background: var(--color-gray-100); border-radius: 8px; margin-bottom: 2rem;">
                <h3 style="color: var(--color-gray-800); margin-bottom: 1rem; font-size: 1.3rem;">現在お問い合わせフォームは準備中です</h3>
                <p style="color: var(--color-gray-600); margin: 0; line-height: 1.6;">
                    運用体制が整い次第、受付を開始いたします。<br>ご不便をおかけしますが、今しばらくお待ちください。
                </p>
            </div>

            <% if false # いつでも復活できるようにフォームをコメントアウトしています %>
            <%= form_with url: contact_path, method: :post, local: true, style: "display: flex; flex-direction: column; gap: 1.5rem;" do |f| %>
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">会社名(所属していない場合は「無し」と記入してください) <span style="color: red;">*</span></label>
                    <input type="text" name="contact[company_name]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">お名前 <span style="color: red;">*</span></label>
                    <input type="text" name="contact[name]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">役職</label>
                    <input type="text" name="contact[position]" style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">メールアドレス <span style="color: red;">*</span></label>
                    <input type="email" name="contact[email]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">電話番号 <span style="color: red;">*</span></label>
                    <input type="tel" name="contact[phone]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">お問い合わせ内容 <span style="color: red;">*</span></label>
                    <textarea name="contact[message]" required rows="6" style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;"></textarea>
                </div>

                <div style="text-align: center; margin-top: 1rem;">
                    <button type="submit" class="btn btn-accent btn-large">送信する</button>
                </div>
            <% end %>
            <% end %>
        </div>
    </div>
</div>
