<% content_for :title, "カテゴリ管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-gray-600">セミナーのカテゴリを管理します。</p>
  <%= link_to "新規作成", new_admin_category_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-md">
  <ul role="list" class="divide-y divide-gray-200">
    <% @categories.each do |category| %>
      <li>
        <div class="px-4 py-4 sm:px-6 flex items-center justify-between">
          <div class="flex items-center">
            <div class="flex-shrink-0 h-6 w-6 rounded-full" style="background-color: <%= category.color %>;"></div>
            <div class="ml-4">
              <div class="text-sm font-medium text-blue-600"><%= category.name %></div>
              <div class="text-sm text-gray-500">/<%= category.slug %></div>
            </div>
          </div>
          <div class="flex space-x-2">
            <%= link_to "編集", edit_admin_category_path(category), class: "text-indigo-600 hover:text-indigo-900 bg-indigo-100 hover:bg-indigo-200 px-3 py-1 rounded" %>
            <%= button_to "削除", admin_category_path(category), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "text-red-600 hover:text-red-900 bg-red-100 hover:bg-red-200 px-3 py-1 rounded", style: "border: none; cursor: pointer;" %>
          </div>
        </div>
      </li>
    <% end %>
    <% if @categories.empty? %>
      <li class="px-4 py-8 text-center text-gray-500">カテゴリがまだありません。</li>
    <% end %>
  </ul>
</div>
