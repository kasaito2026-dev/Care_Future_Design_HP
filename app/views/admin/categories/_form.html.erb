<%= form_with(model: @category, url: @category.persisted? ? admin_category_path(@category) : admin_categories_path, class: "space-y-6 bg-white shadow px-4 py-5 sm:rounded-lg sm:p-6") do |f| %>
  <% if @category.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= @category.errors.count %>件のエラーが発生しました</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% @category.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "カテゴリ名", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.text_field :name, class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border", required: true %>
    </div>
  </div>

  <div>
    <%= f.label :slug, "URLスラッグ（半角英数字とハイフン）", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.text_field :slug, class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border", required: true %>
    </div>
  </div>

  <div>
    <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.text_area :description, rows: 3, class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border border-gray-300 rounded-md p-2" %>
    </div>
  </div>

  <div>
    <%= f.label :color, "テーマカラー (HEX値)", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1 flex items-center space-x-2">
      <%= f.color_field :color, class: "h-10 w-20 border border-gray-300 rounded-md cursor-pointer" %>
      <span class="text-sm text-gray-500">例: #3B82F6</span>
    </div>
  </div>

  <div class="pt-5 flex justify-end space-x-3">
    <%= link_to "キャンセル", admin_categories_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <%= f.submit "保存", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
