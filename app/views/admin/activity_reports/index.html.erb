<% content_for :title, "活動報告管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-gray-600">日々の活動報告を管理します。</p>
  <%= link_to "新規作成", new_admin_activity_report_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-md">
  <ul role="list" class="divide-y divide-gray-200">
    <% @reports.each do |report| %>
      <li>
        <div class="px-4 py-4 sm:px-6 flex flex-col md:flex-row md:items-center justify-between">
          <div class="flex flex-col">
            <div class="text-lg font-medium text-blue-600 truncate mb-1">
              <%= report.is_published ? "🟢" : "⚫️" %> <%= report.title %>
            </div>
            <div class="text-sm text-gray-500 flex space-x-4">
              <span>📅 <%= report.published_at&.strftime('%Y年%m月%d日 %H:%M') || "未公開" %></span>
              <span>📝 <%= truncate(report.content, length: 30) %></span>
            </div>
          </div>
          <div class="flex space-x-2 mt-4 md:mt-0">
            <%= link_to "編集", edit_admin_activity_report_path(report), class: "text-indigo-600 hover:text-indigo-900 bg-indigo-100 hover:bg-indigo-200 px-3 py-1 rounded" %>
            <%= link_to "削除", admin_activity_report_path(report), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-red-600 hover:text-red-900 bg-red-100 hover:bg-red-200 px-3 py-1 rounded" %>
          </div>
        </div>
      </li>
    <% end %>
    <% if @reports.empty? %>
      <li class="px-4 py-8 text-center text-gray-500">活動報告がまだありません。</li>
    <% end %>
  </ul>
</div>
