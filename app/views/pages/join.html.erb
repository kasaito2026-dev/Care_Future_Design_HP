<div class="page-header">
    <div class="container">
        <span class="page-label">Membership</span>
        <h1 class="page-title">入会申込</h1>
    </div>
</div>

<div class="content-area py-section">
    <div class="container">
        <div class="contact-form-area fade-in" style="max-width: 700px; margin: 0 auto;">


            <% if flash[:notice] %>
                <div style="background: #d4edda; color: #155724; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
                    <%= flash[:notice] %>
                </div>
            <% end %>

            <!-- 会員プランのご案内 -->
            <div style="margin-bottom: 3rem;">
                <div style="text-align: center; margin-bottom: 2rem;">
                    <h3 style="display: inline-block; margin: 0; color: var(--color-primary); font-size: 1.5rem; position: relative; padding-bottom: 10px;">
                        会員プランのご案内
                        <span style="position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40px; height: 3px; background-color: var(--color-accent); border-radius: 2px;"></span>
                    </h3>
                </div>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
                    
                    <!-- 個人プラン -->
                    <div style="background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); overflow: hidden; border: 1px solid rgba(0,0,0,0.05); transition: transform 0.3s ease;">
                        <div style="background: linear-gradient(135deg, var(--color-primary) 0%, #3498db 100%); padding: 1.5rem; text-align: center; color: white;">
                            <h4 style="margin: 0; font-size: 1.25rem; font-weight: 600; letter-spacing: 1px;">個人プラン</h4>
                        </div>
                        <div style="padding: 2rem;">
                            <div style="text-align: center; margin-bottom: 1.5rem; border-bottom: 1px dashed var(--color-gray-200); padding-bottom: 1.5rem;">
                                <span style="font-size: 0.9rem; color: var(--color-gray-500); font-weight: 500;">月額</span>
                                <div style="color: var(--color-gray-800); font-size: 2rem; font-weight: 700; margin: 0.5rem 0;">1,000<span style="font-size: 1rem; font-weight: 500;">円</span></div>
                                <span style="font-size: 0.85rem; color: var(--color-gray-500); background: #f8f9fa; padding: 4px 12px; border-radius: 20px;">1口単位</span>
                            </div>
                            <ul style="margin: 0; padding: 0; list-style: none; color: var(--color-gray-700); font-size: 0.95rem;">
                                <li style="position: relative; padding-left: 1.8rem; margin-bottom: 0.8rem;">
                                    <span style="position: absolute; left: 0; top: 2px; color: var(--color-primary); font-weight: bold;">✓</span>
                                    セミナーへの参加が可能
                                </li>
                                <li style="position: relative; padding-left: 1.8rem;">
                                    <span style="position: absolute; left: 0; top: 2px; color: var(--color-primary); font-weight: bold;">✓</span>
                                    会員限定コンテンツの閲覧等
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- 法人プラン -->
                    <div style="background: white; border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.12); overflow: hidden; border: 2px solid #1a365d; position: relative; transform: translateY(-5px);">
                        <div style="background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%); padding: 1.5rem; text-align: center; color: white;">
                            <h4 style="margin: 0; font-size: 1.25rem; font-weight: 600; letter-spacing: 1px;">法人プラン</h4>
                        </div>
                        <div style="padding: 2rem;">
                            <div style="text-align: center; margin-bottom: 1.5rem; border-bottom: 1px dashed var(--color-gray-200); padding-bottom: 1.5rem;">
                                <span style="font-size: 0.9rem; color: var(--color-gray-500); font-weight: 500;">月額</span>
                                <div style="color: var(--color-gray-800); font-size: 2rem; font-weight: 700; margin: 0.5rem 0;">10,000<span style="font-size: 1rem; font-weight: 500;">円</span></div>
                                <span style="font-size: 0.85rem; color: var(--color-gray-500); background: #f8f9fa; padding: 4px 12px; border-radius: 20px;">1口単位</span>
                            </div>
                            <ul style="margin: 0; padding: 0; list-style: none; color: var(--color-gray-700); font-size: 0.95rem;">
                                <li style="position: relative; padding-left: 1.8rem; margin-bottom: 0.8rem;">
                                    <span style="position: absolute; left: 0; top: 2px; color: #1a365d; font-weight: bold;">✓</span>
                                    全セミナーに、法人内から3名まで参加が可能
                                </li>
                                <li style="position: relative; padding-left: 1.8rem; margin-bottom: 0.8rem;">
                                    <span style="position: absolute; left: 0; top: 2px; color: #1a365d; font-weight: bold;">✓</span>
                                    ITエンジニアへチャットを利用した無料相談可能
                                </li>
                                <li style="position: relative; padding-left: 1.8rem;">
                                    <span style="position: absolute; left: 0; top: 2px; color: #1a365d; font-weight: bold;">✓</span>
                                    ホームページURLと、会社紹介記事を掲載可能
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div style="background: #f8f9fa; padding: 2rem; border-radius: 12px; border: 1px solid var(--color-gray-200);">
                <div style="text-align: center; margin-bottom: 2rem;">
                    <p style="color: var(--color-gray-700); font-size: 1.05rem; line-height: 1.6; margin: 0;">
                        入会をご希望の方は、以下のフォームに必要事項をご入力の上送信して下さい。
                    </p>
                </div>

                <div style="text-align: center; padding: 40px; background: var(--color-white); border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--color-gray-200);">
                    <h3 style="color: var(--color-gray-800); margin-bottom: 1rem; font-size: 1.3rem;">現在入会申し込みフォームは準備中です</h3>
                    <p style="color: var(--color-gray-600); margin: 0; line-height: 1.6;">
                        運用体制が整い次第、受付を開始いたします。<br>ご案内まで今しばらくお待ちください。
                    </p>
                </div>

                <% if false # いつでも復活できるようにフォームをコメントアウトしています %>
                <%= form_with url: join_path, method: :post, local: true, style: "display: flex; flex-direction: column; gap: 1.5rem;" do |f| %>
                    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">会社名(所属していない場合は「無し」と記入してください) <span style="color: red;">*</span></label>
                    <input type="text" name="join[company_name]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">お名前 <span style="color: red;">*</span></label>
                    <input type="text" name="join[name]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">役職(任意)</label>
                    <input type="text" name="join[position]" style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">メールアドレス <span style="color: red;">*</span></label>
                    <input type="email" name="join[email]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">電話番号 <span style="color: red;">*</span></label>
                    <input type="tel" name="join[phone]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem;">
                </div>

                <div>
                    <label style="display: block; margin-bottom: 4px; font-weight: 500; color: var(--color-gray-700);">加入プラン <span style="color: red;">*</span></label>
                    <div style="position: relative;">
                        <select name="join[plan]" required style="width: 100%; padding: 12px; border: 1px solid var(--color-gray-300); border-radius: 6px; font-size: 1rem; appearance: none; background-color: white;">
                            <option value="">プランを選択してください</option>
                            <option value="個人プラン">個人プラン</option>
                            <option value="法人プラン">法人プラン</option>
                        </select>
                        <div style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--color-gray-500);">
                            ▼
                        </div>
                    </div>
                </div>

                    <div style="text-align: center; margin-top: 1rem;">
                        <button type="submit" class="btn btn-accent btn-large" style="width: 100%; max-width: 300px;">入会を申し込む</button>
                    </div>
                <% end %>
                <% end %>
            </div>
        </div>
    </div>
</div>
